{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "docker:pinDigests",
    "helpers:pinGitHubActionDigests",
    ":dependencyDashboard",
    ":semanticCommits"
  ],
  "timezone": "Etc/UTC",
  "schedule": ["* 0-4 * * *"],
  "platformAutomerge": false,
  "prConcurrentLimit": 5,
  "prHourlyLimit": 4,
  "labels": ["dependencies"],
  "minimumReleaseAge": "3 days",
  "internalChecksFilter": "strict",
  "lockFileMaintenance": {
    "enabled": true,
    "automerge": true,
    "schedule": ["* 0-4 * * 1"]
  },
  "packageRules": [
    {
      "description": "Automerge non-major updates for stable (>=1.0.0) packages once tests pass",
      "matchUpdateTypes": ["minor", "patch"],
      "matchCurrentVersion": "!/^0/",
      "automerge": true
    },
    {
      "description": "Automerge all devDependencies updates once tests pass",
      "matchDepTypes": ["devDependencies"],
      "automerge": true
    },
    {
      "description": "Automerge GitHub Actions digest, patch and minor updates",
      "matchManagers": ["github-actions"],
      "matchUpdateTypes": ["digest", "pin", "pinDigest", "patch", "minor"],
      "automerge": true
    },
    {
      "description": "Automerge Docker digest and non-major image updates",
      "matchManagers": ["dockerfile", "docker-compose"],
      "matchUpdateTypes": ["digest", "pin", "pinDigest", "patch", "minor"],
      "automerge": true
    },
    {
      "description": "Require manual review for all major updates",
      "matchUpdateTypes": ["major"],
      "automerge": false,
      "labels": ["dependencies", "major-update"]
    },
    {
      "description": "Stay on TypeScript 6.x: the 7.x native-Go port has no stable programmatic API, so svelte-check / @sveltejs/kit (which embed the compiler) break under it. Revisit once the Svelte toolchain adopts the TS 7 API.",
      "matchPackageNames": ["typescript"],
      "matchUpdateTypes": ["major"],
      "enabled": false
    }
  ]
}
